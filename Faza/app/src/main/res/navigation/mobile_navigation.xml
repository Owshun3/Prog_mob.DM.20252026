<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.example.faza.ui.home.HomeFragment"
        android:label="@string/title_home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_dashboard"
        android:name="com.example.faza.ui.PageEntrainement.EntrainementFragment"
        android:label="@string/title_dashboard"
        tools:layout="@layout/fragment_entrainement">
        <action
            android:id="@+id/action_dashboard_to_detail"
            app:destination="@id/navigation_detail" />
    </fragment>

    <fragment
        android:id="@+id/navigation_detail"
        android:name="com.example.faza.ui.PageEntrainement.EntrainementDetailFragment"
        android:label="Détail Entraînement"
        tools:layout="@layout/fragment_entrainement_detail" />

    <fragment
        android:id="@+id/navigation_notifications"
        android:name="com.example.faza.ui.notifications.NotificationsFragment"
        android:label="@string/title_notifications"
        tools:layout="@layout/fragment_notifications" />
</navigation>